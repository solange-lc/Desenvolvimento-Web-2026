      background-color: rgba(8, 122, 113, 0.877);
  
}

#profile{
       height: 70px;
       width:70px ;
       border:solid 1px  #fff;
       border-radius:50%;
      background-image: url(imagem.jpg);
      background-size: cover;
      margin:auto;

}  
#username{
      color: #f8fffd;
      text-align: center;
}
.buttonlist{
      background-color: white;
      border-radius: 20px;
      font-size: 10px;
      text-align: center;
      padding: 15px;
      width: 50%;
       margin:auto;
       margin-top: 20px;
}
.redes{
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
    margin-top: 20px;
}

.redes img{
    width: 30px;
    height: 30px;
    cursor: pointer;
}

.redes img:hover{
    transform: scale(1.1);
}
.buttonlist{
    background-color: white;
    border-radius: 20px;
    font-size: 13px;
    text-align: center;
    padding: 13px;
    width: 50%;
    margin: 20px auto;
    display: block;          /* Faz o link parecer um botão */
    text-decoration: none;   /* Remove o sublinhado */
    color: black;
    font-weight: bold;
    transition: 0.3s;
}

.buttonlist:hover{
    background-color: #f0f0f0;
    transform: scale(1.05);
}
.buttonlist{
    cursor: pointer;
}


   



